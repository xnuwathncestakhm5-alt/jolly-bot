อ*(ไฟล์นี้ปล่อยให้มันอยู่เฉย ๆ เลยครับ มันจะทำหน้าที่เป็นสมุดบัญชีคอยจดว่าใครมีกี่เหรียญให้อัตโนมัติ)*

---

### 💻 โค้ดชุดใหม่สำหรับไฟล์ `index.js`

ให้พี่ก๊อปปี้โค้ดทั้งหมดด้านล่างนี้ ไปวางทับในไฟล์ `index.js` ทั้งในคอม และบนหน้าเว็บ GitHub ได้เลยครับ:

```javascript
const { Client, GatewayIntentBits, SlashCommandBuilder, Routes, PermissionFlagsBits, EmbedBuilder } = require('discord.js');
const express = require('express');
const fs = require('fs');
const path = require('path');

const app = express();
const port = 3000;

// ระบบ Web Server เพื่อกันบอทหลับบน Render
app.get('/', (req, res) => { res.send('Jolly Economy Bot is awake!'); });
app.listen(port, () => { console.log(`Web Server พร้อมทำงานที่พอร์ต ${port}`); });

// สร้างตัวแปร Client
const client = new Client({
    intents: [
        GatewayIntentBits.Guilds,
        GatewayIntentBits.GuildMessages,
        GatewayIntentBits.MessageContent,
        GatewayIntentBits.GuildVoiceStates
    ]
});

// แหล่งเก็บข้อมูลไฟล์บัญชีเหรียญ
const COIN_FILE = path.join(__dirname, 'coins.json');

// ฟังก์ชันโหลดข้อมูลเหรียญ
function loadData() {
    try {
        if (!fs.existsSync(COIN_FILE)) fs.writeFileSync(COIN_FILE, '{}');
        return JSON.parse(fs.readFileSync(COIN_FILE, 'utf8'));
    } catch (err) {
        return {};
    }
}

// ฟังก์ชันเซฟข้อมูลเหรียญ
function saveData(data) {
    fs.writeFileSync(COIN_FILE, JSON.stringify(data, null, 2));
}

// -------------------------------------------------------------
// ตั้งค่ากำหนดไอดีระบบฟาร์มเหรียญ (พี่เอาไอดีมาเปลี่ยนตรงนี้ได้เลย)
// -------------------------------------------------------------
const TARGET_VC_ID = '1513129957641949247'; // 🔊 เปลี่ยนเป็นไอดีห้อง Voice Channel ที่อยากให้ฟาร์มเงิน
const COINS_PER_CHAT = 2;                  // 💬 พิมพ์คุยได้ครั้งละกี่เหรียญ
const COINS_PER_5MIN = 10;                 // ⏰ สิงห้อง VC ทุก 5 นาทีได้กี่เหรียญ

// -------------------------------------------------------------
// สร้างคำสั่ง Slash Commands (/) ลบของเก่า สร้างระบบเหรียญใหม่
// -------------------------------------------------------------
client.once('ready', async () => {
    console.log(`บอท ${client.user.tag} ออนไลน์พร้อมระบบเหรียญแล้ว!`);

    const commands = [
        // 1. คำสั่งเช็คเหรียญตัวเอง
        new SlashCommandBuilder().setName('wallet').setDescription('ตรวจสอบเหรียญในกระเป๋าของคุณและรายการของรางวัล'),
        
        // 2. เกมเป่ายิ้งฉุบ (วันละครั้ง)
        new SlashCommandBuilder().setName('rps')
            .setDescription('เล่นเกมเป่ายิ้งฉุบเดิมพันเหรียญ (เล่นได้วันละ 1 ครั้ง)')
            .addStringOption(option => 
                option.setName('choice').setDescription('เลือกอาวุธของคุณ').setRequired(true)
                .addChoices(
                    { name: '👊 ค้อน', value: 'rock' },
                    { name: '✋ กระดาษ', value: 'paper' },
                    { name: '✌️ กรรไกร', value: 'scissors' }
                )
            )
            .addIntegerOption(option => option.setName('bet').setDescription('จำนวนเหรียญที่ต้องการเดิมพัน').setRequired(true)),

        // 3. คำสั่งแอดมิน เสกเหรียญ
        new SlashCommandBuilder().setName('addcoin')
            .setDescription('[ADMIN ONLY] เสกเหรียญให้กับผู้เล่น')
            .setDefaultMemberPermissions(PermissionFlagsBits.Administrator)
            .addUserOption(option => option.setName('user').setDescription('เลือกคนที่ต้องการให้เหรียญ').setRequired(true))
            .addIntegerOption(option => option.setName('amount').setDescription('จำนวนเหรียญที่จะเสก').setRequired(true))
    ];

    try {
        console.log('กำลังรีเซ็ตและลงทะเบียนคำสั่ง (/) ระบบใหม่...');
        await client.application.commands.set(commands);
        console.log('ลงทะเบียนคำสั่ง (/) สำเร็จแล้ว!');
    } catch (error) {
        console.error(error);
    }

    // เปิดลูปตรวจคนในห้องเสียงทุกๆ 5 นาที (300000 มิลลิวินาที)
    setInterval(() => {
        const db = loadData();
        const guild = client.guilds.cache.first(); // ดึงเซิร์ฟเวอร์แรกที่บอทอยู่
        if (!guild) return;

        const voiceChannel = guild.channels.cache.get(TARGET_VC_ID);
        if (!voiceChannel) return;

        // แจกเหรียญให้ทุกคนที่นั่งอยู่ในห้อง VC นั้น (ยกเว้นบอท)
        voiceChannel.members.forEach(member => {
            if (member.user.bot) return;
            const userId = member.id;
            if (!db[userId]) db[userId] = { coins: 0, lastRPS: 0 };
            
            db[userId].coins += COINS_PER_5MIN;
            console.log(`⏰ แจกเงินอัตโนมัติให้คุณ ${member.user.username} จำนวน ${COINS_PER_5MIN} เหรียญ จากการอยู่ VC`);
        });
        
        saveData(db);
    }, 300000); 
});

// -------------------------------------------------------------
// ระบบรับเหรียญจากการพิมพ์แชทเรื่อย ๆ (Chat Farming)
// -------------------------------------------------------------
client.on('messageCreate', async (message) => {
    if (message.author.bot || !message.guild) return;

    const db = loadData();
    const userId = message.author.id;

    if (!db[userId]) db[userId] = { coins: 0, lastRPS: 0 };

    // ให้เหรียญทุกครั้งที่พิมพ์คุยกัน
    db[userId].coins += COINS_PER_CHAT;
    saveData(db);
});

// -------------------------------------------------------------
// ระบบควบคุมการทำงานของคำสั่ง Slash Commands (/)
// -------------------------------------------------------------
client.on('interactionCreate', async (interaction) => {
    if (!interaction.isChatInputCommand()) return;

    const db = loadData();
    const userId = interaction.user.id;

    if (!db[userId]) db[userId] = { coins: 0, lastRPS: 0 };

    // --- 1. คำสั่งดูเหรียญร้านค้า (/wallet) ---
    if (interaction.commandName === 'wallet') {
        const embed = new EmbedBuilder()
            .setTitle(`🪙 กระเป๋าเงินของ ${interaction.user.username}`)
            .setDescription(`ตอนนี้คุณมีทั้งหมด **${db[userId].coins}** เหรียญ\n\n🎁 **รายการของรางวัลที่สามารถแลกได้ (ติดต่อแอดมิน):**\n• ยศพิเศษสุดเท่: ใช้ 500 เหรียญ\n• บัตรสิทธิพิเศษในเซิร์ฟ: ใช้ 1,000 เหรียญ\n*(สามารถปรับเปลี่ยนของรางวัลได้ในใจเลยพี่)*`)
            .setColor('#FEE75C')
            .setTimestamp();

        return interaction.reply({ embeds: [embed] });
    }

    // --- 2. คำสั่งมินิเกมเป่ายิ้งฉุบ วันละครั้ง (/rps) ---
    if (interaction.commandName === 'rps') {
        const playerChoice = interaction.options.getString('choice');
        const bet = interaction.options.getInteger('bet');

        // เช็คว่ามีเหรียญพอเดิมพันไหม
        if (db[userId].coins < bet || bet <= 0) {
            return interaction.reply({ content: `❌ คุณมีเหรียญไม่พอเดิมพัน หรือใส่จำนวนไม่ถูกต้อง! (คุณมีอยู่ ${db[userId].coins} เหรียญ)`, ephemeral: true });
        }

        // เช็คเวลาคูลดาวน์ 1 วัน (86400000 มิลลิวินาที)
        const now = Date.now();
        const oneDay = 86400000;
        if (db[userId].lastRPS && (now - db[userId].lastRPS < oneDay)) {
            const timeLeft = oneDay - (now - db[userId].lastRPS);
            const hoursLeft = Math.ceil(timeLeft / (1000 * 60 * 60));
            return interaction.reply({ content: `⏳ วันนี้คุณเล่นไปแล้ว! กรุณารออีกประมาณ ${hoursLeft} ชั่วโมง ถึงจะเล่นได้ใหม่อีกครั้งครับ`, ephemeral: true });
        }

        // บอทสุ่มเลือก
        const choices = ['rock', 'paper', 'scissors'];
        const botChoice = choices[Math.floor(Math.random() * choices.length)];

        // หาผู้ชนะ
        let result = ''; // 'win', 'lose', 'draw'
        if (playerChoice === botChoice) result = 'draw';
        else if (
            (playerChoice === 'rock' && botChoice === 'scissors') ||
            (playerChoice === 'paper' && botChoice === 'rock') ||
            (playerChoice === 'scissors' && botChoice === 'paper')
        ) {
            result = 'win';
        } else {
            result = 'lose';
        }

        // แปลงคำโชว์
        const emojiMap = { rock: '👊 ค้อน', paper: '✋ กระดาษ', scissors: '✌️ กรรไกร' };
        
        let textResult = '';
        if (result === 'draw') {
            textResult = `🤝 **เสมอซะงั้น!** รอบนี้ไม่มีใครเสียเหรียญ`;
        } else if (result === 'win') {
            db[userId].coins += bet;
            textResult = `🎉 **คุณชนะ!** ได้รับเพิ่มอีก **+${bet}** เหรียญ!`;
        } else {
            db[userId].coins -= bet;
            textResult = `😭 **คุณแพ้บอทเอ๋อ!** สูญเสียเงินเดิมพัน **-${bet}** เหรียญ`;
        }

        // บันทึกเวลาที่เล่นไป
        db[userId].lastRPS = now;
        saveData(db);

        const embedRPS = new EmbedBuilder()
            .setTitle('🎯 มินิเกมเป่ายิ้งฉุบ (เดิมพันวันละครั้ง)')
            .addFields(
                { name: 'คุณเลือก', value: emojiMap[playerChoice], inline: true },
                { name: 'บอทเลือก', value: emojiMap[botChoice], inline: true },
                { name: 'ผลลัพธ์', value: textResult }
            )
            .setColor(result === 'win' ? '#57F287' : result === 'lose' ? '#ED4245' : '#95A5A6')
            .setFooter({ text: `ยอดเงินคงเหลือของคุณ: ${db[userId].coins} เหรียญ` });

        return interaction.reply({ embeds: [embedRPS] });
    }

    // --- 3. คำสั่งแอดมินเสกเหรียญ (/addcoin) ---
    if (interaction.commandName === 'addcoin') {
        const targetUser = interaction.options.getUser('user');
        const amount = interaction.options.getInteger('amount');
        const targetId = targetUser.id;

        if (!db[targetId]) db[targetId] = { coins: 0, lastRPS: 0 };

        // ทำการเสกเหรียญเข้าบัญชีเป้าหมาย
        db[targetId].coins += amount;
        saveData(db);

        return interaction.reply({ content: `🪄 **เสกเหรียญสำเร็จ!** เติมเงินให้คุณ **${targetUser.username}** จำนวน **${amount}** เหรียญ เรียบร้อยแล้ว (ยอดรวมปัจจุบัน: ${db[targetId].coins} เหรียญ)` });
    }
});

